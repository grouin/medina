// Variables définies par l'utilisateur.
// - La déclaration se fait avec le symbole "$", l'utilisation avec le symbole "_" (meilleure visibilité).
// - Ne pas utiliser des noms de variables similaires à des mots du texte à traiter (qui existeraient en majuscules).
// - Vérifier qu'il y a une tabulation (et pas des espaces) entre le nom de variable et son contenu.

$PATIENT	(Ms|Ms.)
$DOCTOR	(Dr|Dr.)
$TITLE	(MD|M.D.)
$CAPINI	[A-Z]\p{L}+
$TOKEN	\p{L}+
$INITIALE	[A-Z]\.
$SEP	(\-|\/)
$SPACE	(\-|\.|\/| )
$MONTH	(January|February|March|April|May|June|July|August|September|October|November|December)
$STREET	(Court|Road|Street)
$STATE	[A-Z]{2}


// Noms de personne : Monsieur Jean-Claude Martin ; Mr Jean Martin ; Dr M. Gonzales

DOCTOR	!~_CAPINI\,_SPACE_CAPINI_SPACE_CAPINI~! (_TITLE)
DOCTOR	!~_CAPINI\,_SPACE_CAPINI~! (_TITLE)
DOCTOR	Provider: (_CAPINI)
DOCTOR	_DOCTOR (_CAPINI_SPACE_CAPINI|_CAPINI)

PATIENT	_PATIENT (_CAPINI_SPACE_CAPINI)
PATIENT	Patient: (_CAPINI\,_SPACE_CAPINI)


// dates : 2080-03-13, 02/15/2080, 6/4/80, 2/2080, 2/80, 2080s, 2080, 60s, April, Feb, feb ; [2059;2164] ; /!\ may have, may be...

DATE	(_MONTH \d+, 2[01]\d{2})
DATE	(2[01]\d{2}_SEP\d{2}_SEP\d{2})
DATE	(\d{1,2}_SEP\d{1,2}_SEP2[01]\d{2})
DATE	(\d{1,2}_SEP\d{1,2}_SEP\d{2})
DATE	(\d{1,2}_SEP20\d{2})
DATE	(([12]?[0-9]|3[01])_SEP\d{2})
DATE	(2[01]\d{2}s)
DATE	(2[01]\d{2})
DATE	(\d{2}s)
DATE	(January|February|March|April|May|June|July|August|September|October|November|December|Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec|jan|feb|mar|apr|may|jun|jul|aug|sep|oct|nov|dec)
DATE	(Mo|Tu|We|Th|Fr|Sat|Sa|Sun|Su)
DATE	(M|T|W|F|S)


// Téléphones : (202) 679 3196

CONTACT	(\(\d{3}\) \d{3}[\- ]\d{4})
CONTACT	\#(\d{5})

// Ages : newborn 6 weeks old, 66-year-old, 66yo, 66M, 66F

AGE	!~\d+ weeks~! old
AGE	!~\d+~!(-year-old| year-old| year old| yr old| yrs|yo)
AGE	!~\d+~!\s?[MF]


// Zip

ZIP	(_STATE) !~\d{5}~!

STREET	(\d+ _CAPINI _STREET)

PROFESSION	Works as !~[A-Za-z]{4,}~!
ORGANIZATION	for !~[A-Z][a-z]{3,}~!
