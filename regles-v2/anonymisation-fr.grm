// Variables définies par l'utilisateur.
// - La déclaration se fait avec le symbole "$", l'utilisation avec le symbole "_" (meilleure visibilité).
// - Ne pas utiliser des noms de variables similaires à des mots du texte à traiter (qui existeraient en majuscules).
// - Vérifier qu'il y a une tabulation (et pas des espaces) entre le nom de variable et son contenu.

$PATIENT	(madame|mademoiselle|monsieur|Madame|Mademoiselle|Monsieur|Mme|Melle|M\.|Me|Mr|ME|MR|NOM :|PRENOM :|Nom :|Prénom :|Monsieur :|Madame :)
$MEDECIN	(docteur|professeur|Docteur|Professeur|Dr\.|Pr\.|dr\.|dr|Dr|Pr|DR|PR|CH)
$FONCTIONS	(Aides :|Aides:|Opérateur :|Opérateur:)
$HOPITAL	(Centre Hospitalier|CHU|CHR|CH|Clinique|HÔPITAL|HOPITAL|Hôpital|Polyclinique|Salle|Service|Unité|centre hospitalier|clinique|hôpital|polyclinique|salle|service|unité|l'hôpital|l'unité)
$RUE	(avenue|boulevard|chemin|place|rue|square|Avenue|Boulevard|Bd|Chemin|Place|Rue|Square|AVENUE|BOULEVARD|BD|CHEMIN|PLACE|RUE|SQUARE)
$MOIS	(janvier|février|mars|avril|mai|juin|juillet|août|septembre|octobre|novembre|décembre|Janvier|Février|Mars|Avril|Mai|Juin|Juillet|Août|Septembre|Octobre|Novembre|Décembre)
$MCONS	(janvier|février|mars|mai|juin|juillet|septembre|novembre|décembre|Janvier|Février|Mars|Mai|Juin|Juillet|Septembre|Novembre|Décembre)
$MVOY	(avril|août|octobre|Avril|Août|Octobre)
$PREPVILLE	(en|la|le|les|sous|sur)
$PREPADR	(du |des |de l'|de la |de |)
$BISTER	([A-Z]|bis|ter|)
$CEDEX	(CEDEX|Cedex|cedex)
$PARTICULE	(Al|Ben|Da|De|Di|Du|La|Le|Mac|Mc|O|van|Van|von|Von|AL|BEN|DA|DE|DI|DU|LA|LE|MAC|MC|VAN|VAN|VON|VON|)
$CAPINI	[A-Z]\p{L}+
$TOKEN	\p{L}+
$INITIALE	[A-Z]\.
$CHIFFRE	[\dO]
$NUMMO	(1|2|3|4|5|6|7|8|9|01|02|03|04|05|06|07|08|09|10|11|12)
$SEP	(\-|\.|\/)
$SPACE	(\-|\.|\/| )
$SERIE	(série :\s?|SN\s?)
$MARQUE	(CPI|Ela Medical|Guidant|Medtronic|Sorin|St Jude Médical|CARTO|ELA MEDICAL|GUIDANT|MEDTRONIC|SORIN|ST JUDE MÉDICAL)
$MODELE	(Acuity|BRIO|Endotak Regence SG|Mozaic|MERGE|Microny|Sigma|Vitality)


// Hôpitaux

hopital	(ASSISTANCE PUBLIQUE - HOPITAUX DE PARIS|Assistance Publique - Hôpitaux de Paris|_HOPITAL SAINT-ANTOINE|_HOPITAL TROUSSEAU|TROUSSEAU|_HOPITAL NOTRE_SPACE?DAME DE BON SECOURS|_HOPITAL Saint_SPACEVincent_SPACEde_SPACEPaul|CENTRE HOSPITALIER UNIVERSITAIRE DE RENNES|PONTCHAILLOU)
